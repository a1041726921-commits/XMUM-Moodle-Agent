XMUM_MOODLE_USERNAME=your-campus-id
XMUM_MOODLE_PASSWORD=your-password

# Optional. Defaults shown below.
XMUM_MOODLE_COURSES_URL=https://l.xmu.edu.my/my/
XMUM_AGENT_DATA_DIR=data
XMUM_AGENT_HEADLESS=true

# Course filter. Default behavior is current semester only.
# Leave blank to download all visible Moodle courses.
XMUM_COURSE_INCLUDE_REGEX=2026/04
XMUM_COURSE_EXCLUDE_REGEX=
